# ── LLM (pick one or leave blank to skip AI analysis) ──────────
# Option A: OpenAI
OPENAI_API_KEY=sk-...

# Option B: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Explicit override (optional — auto-detected from key above)
# LLM_PROVIDER=openai   # or: anthropic

# ── OAuth2 Configuration (for passwordless LLM API access) ──────
# OpenAI OAuth2 (get from https://platform.openai.com/account/api-keys)
# OPENAI_OAUTH_CLIENT_ID=your-openai-client-id
# OPENAI_OAUTH_CLIENT_SECRET=your-openai-client-secret

# Anthropic OAuth2 (get from https://console.anthropic.com/settings)
# ANTHROPIC_OAUTH_CLIENT_ID=your-anthropic-client-id
# ANTHROPIC_OAUTH_CLIENT_SECRET=your-anthropic-client-secret

# Google OAuth2 for Gemini API (get from Google Cloud Console)
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ── Async Queue (Celery + Redis) ────────────────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Auth & Security ─────────────────────────────────────────────
# SECRET_KEY=your-random-secret-key (change in production!)
# FRONTEND_URL=http://localhost:8000

# ── Server ──────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:3000","https://yourapp.com"]
# MAX_ZIP_MB=500
